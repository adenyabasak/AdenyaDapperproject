@model List<AdenyaDapperProject.Models.JobModel>

@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}

<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="fw-bold">Tüm İş İlanları</h1>
        <p class="text-muted">
            Sana uygun freelance işi seç ve hemen teklif ver.
        </p>
    </div>

    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-lg-4 mb-4">

                <div class="premium-job-card">

                    <div class="job-top">

                        <div class="job-icon">
                            <i class="bi bi-briefcase-fill"></i>
                        </div>

                        <div>
                            <h5>@item.Title</h5>
                            <small>@item.CategoryName</small>
                        </div>

                    </div>

                    <p class="mt-3 text-muted">
                        @item.Description
                    </p>

                    <div class="job-footer">

                        <span class="price">
                            @item.Budget.ToString("N0") ₺
                        </span>

                        <a href="/Bid/Create" class="btn btn-primary">
                            Teklif Ver
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>