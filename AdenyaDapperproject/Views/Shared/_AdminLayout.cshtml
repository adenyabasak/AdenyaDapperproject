@{
    var fullName = Context.Session.GetString("FullName");
    var role = Context.Session.GetString("Role");
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Adenya Freelance Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
            body {
                background: #f3f5fb;
                font-family: 'Segoe UI', sans-serif;
            }

            .admin-wrapper {
                display: flex;
                min-height: 100vh;
            }

            .sidebar {
                width: 270px;
                background: linear-gradient(180deg, #111827, #1e1b4b);
                color: white;
                padding: 25px 20px;
                position: fixed;
                height: 100vh;
            }

            .brand {
                font-size: 23px;
                font-weight: 800;
                margin-bottom: 35px;
                letter-spacing: .5px;
            }

                .brand span {
                    color: #38bdf8;
                }

            .menu-title {
                font-size: 12px;
                color: #94a3b8;
                margin: 25px 0 10px;
                text-transform: uppercase;
            }

            .sidebar a {
                display: flex;
                align-items: center;
                gap: 12px;
                color: #dbeafe;
                text-decoration: none;
                padding: 13px 14px;
                border-radius: 14px;
                margin-bottom: 7px;
                transition: .25s;
                font-weight: 500;
            }

                .sidebar a:hover {
                    background: rgba(255,255,255,.12);
                    transform: translateX(5px);
                    color: white;
                }

            .content {
                margin-left: 270px;
                width: calc(100% - 270px);
                padding: 25px;
            }

            .topbar {
                background: white;
                border-radius: 22px;
                padding: 18px 25px;
                box-shadow: 0 15px 35px rgba(15,23,42,.08);
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 25px;
            }

                .topbar h4 {
                    margin: 0;
                    font-weight: 800;
                    color: #0f172a;
                }

            .user-box {
                display: flex;
                align-items: center;
                gap: 12px;
                background: #f1f5f9;
                padding: 10px 15px;
                border-radius: 16px;
            }

            .avatar {
                width: 42px;
                height: 42px;
                border-radius: 50%;
                background: linear-gradient(135deg, #2563eb, #38bdf8);
                color: white;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: 800;
            }

            .page-card {
                background: white;
                border-radius: 24px;
                padding: 25px;
                box-shadow: 0 15px 35px rgba(15,23,42,.08);
            }

            .btn {
                border-radius: 12px;
            }

            .table {
                vertical-align: middle;
            }

                .table thead {
                    background: #eff6ff;
                    color: #1e3a8a;
                }

            input.form-control,
            select.form-control {
                border-radius: 13px;
                padding: 11px 14px;
            }

            @@media (max-width: 900px) {
                .sidebar {
                    position: relative;
                    width: 100%;
                    height: auto;
                }

                .admin-wrapper {
                    display: block;
                }

                .content {
                    margin-left: 0;
                    width: 100%;
                }
            }
    </style>
</head>

<body>
    <div class="admin-wrapper">

        <aside class="sidebar">
            <div class="brand">
                Adenya<span>Freelance</span>
            </div>

            @if (role == "Admin")
            {
                <div class="menu-title">Yönetim</div>

                <a href="/Report/Index">
                    <i class="bi bi-speedometer2"></i>
                    Dashboard / Rapor
                </a>

                <a href="/User/Index">
                    <i class="bi bi-people"></i>
                    Kullanıcılar
                </a>

                <a href="/Category/Index">
                    <i class="bi bi-grid"></i>
                    Kategoriler
                </a>
            }

            <div class="menu-title">İşlemler</div>

            <a href="/Job/Index">
                <i class="bi bi-briefcase"></i>
                İş İlanları
            </a>

            <a href="/Bid/Index">
                <i class="bi bi-cash-coin"></i>
                Teklifler
            </a>

            <div class="menu-title">Site</div>

            <a href="/Home/Index">
                <i class="bi bi-house"></i>
                Ana Sayfa
            </a>

            <a href="/Account/Logout">
                <i class="bi bi-box-arrow-right"></i>
                Çıkış Yap
            </a>
        </aside>

        <main class="content">
            <div class="topbar">
                <div>
                    <h4>Freelance Yönetim Paneli</h4>
                    <small class="text-muted">
                        @(role == "Admin" ? "Admin yönetim ekranı" : "Kullanıcı iş ve teklif ekranı")
                    </small>
                </div>

                <div class="user-box">
                    <div class="avatar">
                        @(string.IsNullOrEmpty(fullName) ? "A" : fullName.Substring(0, 1))
                    </div>
                    <div>
                        <strong>@fullName</strong>
                        <br />
                        <small class="text-muted">@role</small>
                    </div>
                </div>
            </div>

            <div class="page-card">
                @RenderBody()
            </div>
        </main>

    </div>
</body>
</html>