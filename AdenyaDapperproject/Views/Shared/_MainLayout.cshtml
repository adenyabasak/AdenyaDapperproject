@{
    var fullName = Context.Session.GetString("FullName");
    var role = Context.Session.GetString("Role");
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Adenya Freelance</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
            body {
                font-family: 'Segoe UI', sans-serif;
                background: #f8fafc;
                color: #0f172a;
            }

            .main-navbar {
                background: white;
                padding: 18px 0;
                box-shadow: 0 10px 30px rgba(15,23,42,.08);
            }

            .logo {
                font-size: 25px;
                font-weight: 900;
                color: #0f172a;
                text-decoration: none;
            }

                .logo span {
                    color: #2563eb;
                }

            .nav-link {
                font-weight: 600;
                color: #334155 !important;
                margin-left: 15px;
            }

                .nav-link:hover {
                    color: #2563eb !important;
                }

            .hero {
                background: linear-gradient(135deg, #0f172a, #1e3a8a, #2563eb);
                color: white;
                padding: 90px 0;
                border-radius: 0 0 45px 45px;
            }

                .hero h1 {
                    font-size: 52px;
                    font-weight: 900;
                    line-height: 1.1;
                }

                .hero p {
                    font-size: 19px;
                    color: #dbeafe;
                    margin-top: 20px;
                }

            .hero-card {
                background: rgba(255,255,255,.12);
                backdrop-filter: blur(12px);
                border: 1px solid rgba(255,255,255,.25);
                border-radius: 28px;
                padding: 30px;
                box-shadow: 0 25px 60px rgba(0,0,0,.25);
            }

            .feature-box {
                background: white;
                border-radius: 24px;
                padding: 30px;
                box-shadow: 0 15px 35px rgba(15,23,42,.08);
                transition: .25s;
                height: 100%;
            }

                .feature-box:hover {
                    transform: translateY(-7px);
                }

                .feature-box i {
                    font-size: 38px;
                    color: #2563eb;
                }

            .job-card {
                background: white;
                border-radius: 25px;
                padding: 25px;
                box-shadow: 0 15px 35px rgba(15,23,42,.08);
                transition: .25s;
                height: 100%;
                border: 1px solid #e5e7eb;
            }

                .job-card:hover {
                    transform: translateY(-6px);
                    border-color: #2563eb;
                }

            .job-price {
                background: #eff6ff;
                color: #2563eb;
                padding: 8px 14px;
                border-radius: 999px;
                font-weight: 800;
                display: inline-block;
            }

            .section-title {
                font-weight: 900;
                margin-bottom: 35px;
            }

            .main-footer {
                background: #0f172a;
                color: #cbd5e1;
                padding: 35px 0;
                margin-top: 70px;
            }

            .btn-main {
                background: #2563eb;
                color: white;
                border-radius: 14px;
                padding: 11px 22px;
                font-weight: 700;
            }

                .btn-main:hover {
                    background: #1d4ed8;
                    color: white;
                }

            .btn-light-main {
                background: white;
                color: #2563eb;
                border-radius: 14px;
                padding: 11px 22px;
                font-weight: 700;
            }


            /* ================= HERO PREMIUM ================= */

            .premium-hero {
                position: relative;
                overflow: hidden;
                padding: 120px 0;
                background: radial-gradient(circle at top right,#3b82f6 0,#1d4ed8 25%,#0f172a 70%);
            }

            .hero-badge {
                display: inline-block;
                background: rgba(255,255,255,.15);
                color: white;
                backdrop-filter: blur(10px);
                padding: 10px 18px;
                border-radius: 999px;
                font-weight: 600;
                margin-bottom: 25px;
            }

            .premium-hero h1 {
                font-size: 68px;
                font-weight: 900;
                color: white;
                line-height: 1.05;
            }

                .premium-hero h1 span {
                    color: #60a5fa;
                }

            .premium-hero p {
                color: #dbeafe;
                font-size: 20px;
                margin: 30px 0;
                line-height: 1.8;
            }

            .hero-buttons {
                display: flex;
                gap: 15px;
            }

            .hero-glass-card {
                background: rgba(255,255,255,.12);
                backdrop-filter: blur(18px);
                border: 1px solid rgba(255,255,255,.2);
                border-radius: 30px;
                padding: 35px;
                color: white;
                position: relative;
                box-shadow: 0 35px 60px rgba(0,0,0,.3);
                transition: .4s;
            }

                .hero-glass-card:hover {
                    transform: translateY(-12px);
                }

            .job-preview {
                display: flex;
                gap: 18px;
                align-items: center;
                margin: 30px 0;
            }

            .job-icon {
                width: 70px;
                height: 70px;
                border-radius: 20px;
                background: white;
                color: #2563eb;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 28px;
            }

            .preview-price {
                background: white;
                color: #2563eb;
                padding: 12px 18px;
                border-radius: 15px;
                font-weight: 800;
                display: inline-block;
            }

            .preview-stats {
                display: flex;
                justify-content: space-between;
                margin-top: 35px;
            }

                .preview-stats div {
                    text-align: center;
                }

                .preview-stats strong {
                    display: block;
                    font-size: 24px;
                }

                .preview-stats span {
                    color: #dbeafe;
                    font-size: 14px;
                }

            .hero-blur {
                position: absolute;
                border-radius: 50%;
                filter: blur(100px);
            }

            .hero-blur-1 {
                width: 300px;
                height: 300px;
                background: #38bdf8;
                right: -120px;
                top: -80px;
                opacity: .25;
            }

            .hero-blur-2 {
                width: 220px;
                height: 220px;
                background: #818cf8;
                left: -70px;
                bottom: -70px;
                opacity: .25;
            }

            .floating-dot {
                position: absolute;
                border-radius: 50%;
            }

            .dot-1 {
                width: 15px;
                height: 15px;
                background: #38bdf8;
                top: 20px;
                right: 25px;
            }

            .dot-2 {
                width: 8px;
                height: 8px;
                background: white;
                top: 45px;
                right: 55px;
            }

            /* ================= STATS ================= */

            .stats-section {
                margin-top: -45px;
                position: relative;
                z-index: 5;
            }

            .stats-wrapper {
                background: white;
                border-radius: 30px;
                padding: 35px;
                box-shadow: 0 25px 60px rgba(15,23,42,.13);
                display: grid;
                grid-template-columns: repeat(4,1fr);
                gap: 25px;
            }

            .stat-item {
                text-align: center;
                padding: 20px;
                border-radius: 22px;
                transition: .3s;
            }

                .stat-item:hover {
                    background: #eff6ff;
                    transform: translateY(-7px);
                }

                .stat-item i {
                    font-size: 38px;
                    color: #2563eb;
                }

                .stat-item h2 {
                    margin-top: 12px;
                    font-weight: 900;
                    color: #0f172a;
                }

                .stat-item p {
                    color: #64748b;
                    font-weight: 600;
                }



            /*================ JOB CARDS ================*/

            .premium-job-card {
                background: white;
                border-radius: 26px;
                padding: 28px;
                transition: .35s;
                box-shadow: 0 15px 40px rgba(0,0,0,.08);
                height: 100%;
                border: 1px solid #edf2f7;
            }

                .premium-job-card:hover {
                    transform: translateY(-12px);
                    box-shadow: 0 25px 55px rgba(37,99,235,.18);
                }

            .job-top {
                display: flex;
                align-items: center;
                gap: 18px;
            }

            .job-icon {
                width: 65px;
                height: 65px;
                background: #2563eb;
                color: white;
                border-radius: 18px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 28px;
            }

            .job-footer {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-top: 25px;
            }

            .price {
                font-size: 22px;
                font-weight: 800;
                color: #2563eb;
            }

            .cta-box {
                background: linear-gradient(135deg,#0f172a,#2563eb);
                color: white;
                border-radius: 35px;
                padding: 70px 30px;
                box-shadow: 0 25px 60px rgba(37,99,235,.25);
            }

                .cta-box h2 {
                    font-weight: 900;
                }

                .cta-box p {
                    color: #dbeafe;
                    font-size: 18px;
                    margin: 18px 0 28px;
                }

    </style>
</head>

<body>

    <nav class="main-navbar">
        <div class="container d-flex justify-content-between align-items-center">
            <a href="/Home/Index" class="logo">Adenya<span>Freelance</span></a>

            <div>
                <a href="/Home/Index" class="nav-link d-inline-block">Ana Sayfa</a>
                <a href="/Home/Jobs" class="nav-link d-inline-block">İşler</a>
                <a href="/Home/About" class="nav-link d-inline-block">Hakkımızda</a>
                <a href="/Home/Contact" class="nav-link d-inline-block">İletişim</a>

                @if (string.IsNullOrEmpty(fullName))
                {
                    <a href="/Account/Login" class="btn btn-main ms-3">Giriş Yap</a>
                }
                else
                {
                    @if (role == "Admin")
                    {
                        <a href="/Report/Index" class="btn btn-main ms-3">Admin Panel</a>
                    }

                    <a href="/Account/Logout" class="btn btn-outline-danger ms-2">Çıkış</a>
                }
            </div>
        </div>
    </nav>

    @RenderBody()

    <footer class="main-footer">
        <div class="container d-flex justify-content-between align-items-center">
            <div>
                <strong>AdenyaFreelance</strong>
                <br />
                <small>Freelance iş ve teklif yönetim platformu</small>
            </div>

            <div>
                <small>© 2026 Adenya Freelance Project</small>
            </div>
        </div>
    </footer>

</body>
</html>